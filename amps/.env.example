ANTHROPIC_API_KEY=sk-...
AMPS_MODEL=claude-sonnet-5

# Suno音源生成（Phase2オプション。未設定なら音源生成機能は使わない/使えない）
# EvoLink（https://evolink.ai/suno）を想定。プリペイド・自動チャージOFFのプラン推奨
SUNO_API_KEY=
SUNO_API_BASE_URL=https://api.evolink.ai
SUNO_MODEL=suno-v4.5-beta
# 月間の生成回数上限（プリペイド残高を使い切らないための安全装置。既定150回）
SUNO_MONTHLY_GENERATION_CAP=150
